\newcommand*{\supervisor}[1]{\gdef\@supervisor{#1}%
}

\newcommand{\default@supervisor}{supervisor not set. Por favor.}
% Initially set @supervisor to the default
\newcommand{\@supervisor}{\default@supervisor}

% Single command to list all supervisors, using \and for line breaks
\newcommand*{\supervisors}[1]{%
  \renewcommand{\and}{\\}% Redefine \and to be a line break
  \gdef\@supervisor{#1}%
}

\newcommand{\@carrera}{Licenciado en (setear carrera)} % Default career title

\newcommand*{\carrera}[1]{%
  \ifstrequal{#1}{computacion}{%
    \gdef\@carrera{Ciencias de la Computación }%
  }{%
  \ifstrequal{#1}{astronomia}{%
    \gdef\@carrera{Astronomía }%
  }{%
  \ifstrequal{#1}{fisica}{%
    \gdef\@carrera{Física }%
  }{%
  \ifstrequal{#1}{matematica}{%
    \gdef\@carrera{Matemática }%
  }{%
  \ifstrequal{#1}{matematicaaplicada}{%
    \gdef\@carrera{Matemática Aplicada }%
  }{%
    % Fallback: use the argument as part of the title.
    \gdef\@carrera{Licenciado en #1}%
  }}}}}%
}

